ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:7124;http://localhost:5179

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=lootnet;Username=postgres;Password=postgres

Jwt__Key=local-development-jwt-key-change-me-32-bytes-minimum
Jwt__Issuer=LootNetAPI
Jwt__Audience=LootNetClients
Jwt__AccessTokenMinutes=60
Jwt__RefreshTokenDays=7

Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://localhost:3000

App__PublicBaseUrl=http://localhost:5179
App__WebBaseUrl=http://localhost:5173
App__MobileVerificationBaseUrl=lootnet://verify-email

Swagger__Enabled=true
Development=true

Email__From=no-reply@lootnet.local
Email__Resend__ApiKey=
Email__Smtp__Host=localhost
Email__Smtp__Port=1025
Email__Smtp__Username=
Email__Smtp__Password=
Email__Smtp__EnableSsl=false
